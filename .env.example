PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
STORAGE_ADAPTER=local   # local (default) | vercel
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRY=7d            # e.g. 1d, 7d, 30d
SETUP_TOKEN=change-me-before-first-login  # Required on first login to set admin password; safe to remove after

# Required when STORAGE_ADAPTER=vercel
# POSTGRES_URL=postgres://...          # Vercel Postgres connection string
# BLOB_READ_WRITE_TOKEN=vercel_blob_...  # Vercel Blob token

# Frontend dev server (vite.config.ts reads these at startup — not needed for production builds)
# BACKEND_URL=http://localhost:3001   # override if backend runs on different host/port
# PORT=5173                           # override frontend dev-server port

# Frontend production build — baked into the bundle at build time
# VITE_API_URL=https://your-backend.railway.app  # required when deploying frontend separately (Vercel, etc.)
